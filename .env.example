# ─── Django Core ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-hotel-booking-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ──────────────────────────────────────────────────────────────────
# Leave blank in dev — SQLite is used automatically
# In production, set to your PostgreSQL URL:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# ─── Hold Duration (minutes) ───────────────────────────────────────────────────
HOLD_DURATION_MINUTES=10

# ─── Gmail SMTP (Dev email — OTP & booking confirmations) ──────────────────────
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password   # Use a Gmail App Password, not your real password

# ─── Razorpay Payment Gateway ──────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys (use Test Mode for dev)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Google OAuth (django-allauth) ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── WhatsApp / Interakt ───────────────────────────────────────────────────────
# Get from: https://app.interakt.ai → Settings → Developer Settings
INTERAKT_API_KEY=

# ─── Production Only (leave blank in dev) ─────────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@templetowns.com
REDIS_URL=redis://127.0.0.1:6379/1
SECURE_SSL_REDIRECT=False
DJANGO_LOG_LEVEL=INFO
